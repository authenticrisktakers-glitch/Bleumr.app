# Orbit — environment variable reference
# Copy this file to .env and fill in any values you need.
# API keys are stored securely via Electron safeStorage — do NOT commit real keys here.

# Optional: OpenAI API key (entered in Settings UI at runtime, not needed here)
# OPENAI_API_KEY=

# Optional: Groq API key
# GROQ_API_KEY=

# Set by electron-vite automatically — do not change
# ELECTRON_RENDERER_URL=http://localhost:5173
