{
  "name": "bleumr",
  "version": "1.5.0",
  "description": "Bleumr - AI-powered desktop browser and agent platform",
  "author": {
    "name": "Bleumr",
    "email": "hello@bleumr.app"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node ./node_modules/electron-vite/bin/electron-vite.js dev",
    "dev:renderer": "node ./node_modules/vite/bin/vite.js --config vite.renderer.config.ts",
    "build": "node ./node_modules/electron-vite/bin/electron-vite.js build",
    "preview": "node ./node_modules/electron-vite/bin/electron-vite.js preview",
    "package": "npm run build && node ./node_modules/electron-builder/cli.js",
    "package:mac": "npm run build && node ./node_modules/electron-builder/cli.js --mac",
    "package:win": "npm run build && node ./node_modules/electron-builder/cli.js --win",
    "package:linux": "npm run build && node ./node_modules/electron-builder/cli.js --linux"
  },
  "build": {
    "appId": "com.bleumr.app",
    "productName": "Bleumr",
    "icon": "public/Icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "public/Icon.png",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "publish": {
      "provider": "github",
      "owner": "authenticrisktakers-glitch",
      "repo": "Bleumr.app"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@google/generative-ai": "^0.24.1",
    "@mlc-ai/web-llm": "^0.2.82",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-hover-card": "^1.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.0",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/three": "^0.183.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.0.0",
    "compromise": "^14.14.0",
    "croner": "^9.0.0",
    "electron-updater": "^6.8.3",
    "harper.js": "^0.20.0",
    "input-otp": "^1.4.0",
    "jspdf": "^4.2.1",
    "localforage": "^1.10.0",
    "lucide-react": "^0.469.0",
    "motion": "^11.0.0",
    "postprocessing": "^6.39.0",
    "re-resizable": "^6.9.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.4.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.0",
    "recharts": "^2.14.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.0",
    "tailwind-merge": "^2.6.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.2.0",
    "vaul": "^1.1.0",
    "vercel": "^50.39.0",
    "zustand": "^5.0.12"
  }
}
